{
    "name": "marko/media-gd",
    "description": "GD image processor driver for Marko Framework",
    "license": "MIT",
    "type": "marko-module",
    "require": {
        "php": "^8.5",
        "ext-gd": "*",
        "marko/core": "self.version",
        "marko/media": "self.version"
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "marko/testing": "self.version"
    },
    "autoload": {
        "psr-4": {
            "Marko\\MediaGd\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\MediaGd\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
